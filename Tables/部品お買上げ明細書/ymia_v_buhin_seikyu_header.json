    "CreateViewSql": "select `v`.`対象年月` AS `対象年月`,`v`.`取引先コード` AS `取引先コード`,`t`.`TORIHIKISAKI_NAME` AS `請求先名称`,`t`.`POST_CODE` AS `郵便番号`,`t`.`ADDRESS` AS `住所`,sum(`v`.`金額`) AS `ご請求額`,floor((sum(`v`.`金額`) * 0.1)) AS `消費税額`,count(`v`.`部品コード`) AS `明細件数` from (`ymia_v_buhin_seikyu_meisai` `v` left join `mtorihiki` `t` on((`v`.`取引先コード` = `t`.`TORIHIKISAKI_CODE`))) group by `v`.`対象年月`,`v`.`取引先コード`,`t`.`TORIHIKISAKI_NAME`,`t`.`POST_CODE`,`t`.`ADDRESS`",
