    "SourceTableName": "ymia_v_buhin_seikyu_meisai",
    "SourceTableSchema": "",
    "CreateViewSql": "select `t`.`TORIHIKISAKI_NAME` AS `請求先名称`,`t`.`POST_CODE` AS `郵便番号`,`t`.`ADDRESS` AS `住所`,`h`.`TORIHIKISAKI_CODE` AS `取引先コード`,`a`.`TARGET_YEAR_MONTH` AS `対象年月`,`a`.`SHUKKA_DATE` AS `出荷日`,`a`.`DENSHU` AS `伝種`,`h`.`TEHAI_KOBAN` AS `売上番号`,`a`.`NONYUSAKI_MESHO` AS `納入先`,`m`.`HINBAN` AS `部品コード`,`m`.`HINMEI` AS `部品名称`,`m`.`KEISHIKI` AS `規格寸法`,`a`.`URIAGE_SU` AS `数量`,`m`.`HANBAI_TANKA` AS `単価`,(`a`.`URIAGE_SU` * `m`.`HANBAI_TANKA`) AS `金額`,`nm`.`MEISHO` AS `単位` from (((((`tkansayo_seihinuriage_sonotashukka` `a` join `tjuchu` `h` on((`a`.`JYUCHU_NO` = `h`.`JUCHU_NBR`))) join `mtorihiki` `t` on((`h`.`TORIHIKISAKI_CODE` = `t`.`TORIHIKISAKI_CODE`))) join `tjuchum` `m` on((`a`.`JYUCHU_NO` = `m`.`JUCHU_NBR`))) left join `vw_mhinban` `mb` on((`m`.`HINBAN` = `mb`.`HINBAN`))) left join `mname` `nm` on(((`nm`.`MEISHO_KUBUN` = 48) and (`nm`.`MEISHO_CODE` = `m`.`TANI_CODE`)))) where (`mb`.`BUHIN_KUBUN` <> 1)",
