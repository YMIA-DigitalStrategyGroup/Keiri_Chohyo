  "ExternalDatabaseInfo": {
    "DataBaseType": "6db454c0-531c-4395-9122-921a18942902",
    "ConnectionId": "MySql1",
    "SourceTableName": "ymia_v_thatchum",
    "SourceTableSchema": "",
    "CreateViewSql": "select `t`.`DENPYO_NBR` AS `DENPYO_NBR`,`t`.`HATCHU_NBR` AS `HATCHU_NBR`,`t`.`edaban` AS `EDABAN`,`t`.`BUHIN_KOSEI_ID` AS `BUHIN_KOSEI_ID`,`t`.`SEIBAN` AS `SEIBAN`,`t`.`KO_KOBAN` AS `KO_KOBAN`,`t`.`HINBAN` AS `HINBAN`,`t`.`ZUBAN` AS `ZUBAN`,`t`.`NINSHIKI_NBR` AS `NINSHIKI_NBR`,`t`.`KOTEI_CODE` AS `KOTEI_CODE`,`t`.`KOTEI_SEQ_NBR` AS `KOTEI_SEQ_NBR`,`t`.`KOTEI_JUN` AS `KOTEI_JUN`,`t`.`HINMEI` AS `HINMEI`,`t`.`KEISHIKI` AS `KEISHIKI`,`t`.`MAKER` AS `MAKER`,`t`.`KOBAI_TANTO` AS `KOBAI_TANTO`,`t`.`UKEWATASHI_BASHO` AS `UKEWATASHI_BASHO`,`t`.`SHOYORYO` AS `SHOYORYO`,`t`.`SURYO` AS `SURYO`,`t`.`TANKA` AS `TANKA`,`t`.`KAITO_TANKA` AS `KAITO_TANKA`,`t`.`TSUKA_CODE` AS `TSUKA_CODE`,`t`.`KAWASE_RATE` AS `KAWASE_RATE`,`t`.`KINGAKU` AS `KINGAKU`,`t`.`KINGAKU_YEN` AS `KINGAKU_YEN`,`t`.`KARI_KANRYO_FLAG` AS `KARI_KANRYO_FLAG`,`t`.`KANRYO_FLAG` AS `KANRYO_FLAG`,`t`.`MOTO_HATCHU_NBR` AS `MOTO_HATCHU_NBR`,`t`.`MATOMESAKI_NBR` AS `MATOMESAKI_NBR`,`t`.`SHINSEI_NBR` AS `SHINSEI_NBR`,`t`.`SHINSEI_DATE` AS `SHINSEI_DATE`,`t`.`KAISHI_DATE` AS `KAISHI_DATE`,`t`.`UPLOAD_STATUS` AS `UPLOAD_STATUS`,`t`.`DELETE_FLG` AS `DELETE_FLG`,`t`.`SHOHIN_FLG` AS `SHOHIN_FLG`,`t`.`KOBAI_KUBUN` AS `KOBAI_KUBUN`,`t`.`KAKUTEI_CHUMON_RENKEI_FLAG` AS `KAKUTEI_CHUMON_RENKEI_FLAG`,`t`.`TOROKU_TIMESTAMP` AS `TOROKU_TIMESTAMP`,`t`.`TOROKUSHA_CODE` AS `TOROKUSHA_CODE`,`t`.`KOSHIN_TIMESTAMP` AS `KOSHIN_TIMESTAMP`,`t`.`KOSHINSHA_CODE` AS `KOSHINSHA_CODE`,ifnull(`h`.`KIKAKU`,'') AS `MH_KIKAKU`,ifnull(`h`.`ZUBAN`,'') AS `MH_ZUBAN`,ifnull(`g`.`TANKA`,0) AS `GT_TANKA`,ifnull(`g`.`HIMOKU_CODE`,'') AS `GT_HIMOKU_CODE`,`h`.`BUHIN_KUBUN` AS `BUHIN_KUBUN` from ((`thatchum` `t` left join `mhinban` `h` on((`t`.`HINBAN` = `h`.`HINBAN`))) left join `mgentani` `g` on((`t`.`HINBAN` = `g`.`HINBAN`))) where (`h`.`BUHIN_KUBUN` = 9)",
    "ViewInfo": {
