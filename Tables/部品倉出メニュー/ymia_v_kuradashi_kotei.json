    "SourceTableSchema": "",
    "CreateViewSql": "select `t`.`SEIBAN` AS `иЈҪз•Ә`,coalesce(`t`.`KOTEI_PATTERN_NBR`,'-') AS `е·ҘзЁӢгғ‘гӮҝгғјгғіID`,coalesce(`mp`.`KOTEI_PATTERN_NAME`,'-') AS `е·ҘзЁӢгғ‘гӮҝгғјгғіеҗҚ`,`t`.`KURADASHI_KOTEI` AS `еҖүеҮәе·ҘзЁӢгӮігғјгғү`,coalesce(`kn`.`KOTEI_NAME`,'-') AS `еҖүеҮәе·ҘзЁӢеҗҚ`,coalesce(cast(min(`jm`.`KAISHI_DATE`) as char charset utf8mb4),'-') AS `еҖүеҮәдәҲе®ҡж—Ҙ` from (((`tbuhink` `t` left join `mkotei` `mp` on((`t`.`KOTEI_PATTERN_NBR` = `mp`.`KOTEI_PATTERN_NBR`))) left join `mkoteiname` `kn` on((`t`.`KURADASHI_KOTEI` = `kn`.`KOTEI_CODE`))) left join `tbuhinjm` `jm` on((`t`.`ID` = `jm`.`BUHIN_KOSEI_ID`))) where ((`t`.`KURADASHI_KOTEI` is not null) and (`t`.`KURADASHI_KOTEI` <> '')) group by `t`.`SEIBAN`,`t`.`KOTEI_PATTERN_NBR`,`mp`.`KOTEI_PATTERN_NAME`,`t`.`KURADASHI_KOTEI`,`kn`.`KOTEI_NAME`",
