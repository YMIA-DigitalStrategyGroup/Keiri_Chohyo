    "CreateViewSql": "select `t`.`SEIBAN` AS `製番`,`t`.`KURADASHI_KOTEI` AS `倉出工程コード`,coalesce(`kn`.`KOTEI_NAME`,'-') AS `倉出工程名` from (`tbuhink` `t` left join `mkoteiname` `kn` on((`t`.`KURADASHI_KOTEI` = `kn`.`KOTEI_CODE`))) where ((`t`.`KURADASHI_KOTEI` is not null) and (`t`.`KURADASHI_KOTEI` <> '')) group by `t`.`SEIBAN`,`t`.`KURADASHI_KOTEI`,`kn`.`KOTEI_NAME`",
