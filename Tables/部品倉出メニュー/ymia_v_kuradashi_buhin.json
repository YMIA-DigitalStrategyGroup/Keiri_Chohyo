  "ExternalDatabaseInfo": {
    "DataBaseType": "6db454c0-531c-4395-9122-921a18942902",
    "ConnectionId": "MySql1",
    "SourceTableName": "ymia_v_kuradashi_buhin",
    "SourceTableSchema": "",
    "CreateViewSql": "select `t`.`SEIBAN` AS `製番`,`t`.`HINBAN` AS `倉出品番`,`m`.`HINMEI` AS `品名`,`m`.`KIKAKU` AS `規格・寸法`,`t`.`KURADASHI_KOTEI` AS `倉出工程`,coalesce(group_concat(distinct `hm`.`DENPYO_NBR` order by `hm`.`DENPYO_NBR` ASC separator ', '),'-') AS `伝票番号`,coalesce(cast(min(`jm`.`KAISHI_DATE`) as char charset utf8mb4),'-') AS `倉出予定日`,coalesce(cast((min(`jm`.`KAISHI_DATE`) - interval 4 day) as char charset utf8mb4),'-') AS `倉出4日前`,sum(distinct `t`.`SHOYO_RYO`) AS `予定数量`,`nm`.`MEISHO` AS `単位`,`m`.`TANABAN` AS `ロケーション（棚番）`,(case `t`.`KOBAI_KUBUN` when 0 then '内製' when 1 then '外製' else '-' end) AS `購買区分` from ((((`tbuhink` `t` join (select `m1`.`HINBAN` AS `HINBAN`,`m1`.`HINMEI` AS `HINMEI`,`m1`.`KIKAKU` AS `KIKAKU`,`m1`.`TANI_CODE` AS `TANI_CODE`,`m1`.`TANABAN` AS `TANABAN`,`m1`.`KAITEI_SEQ_NBR` AS `KAITEI_SEQ_NBR` from (`mhinban` `m1` join (select `mhinban`.`HINBAN` AS `HINBAN`,max(`mhinban`.`KAITEI_SEQ_NBR`) AS `max_seq` from `mhinban` group by `mhinban`.`HINBAN`) `m2` on(((`m1`.`HINBAN` = `m2`.`HINBAN`) and (`m1`.`KAITEI_SEQ_NBR` = `m2`.`max_seq`))))) `m` on((`t`.`HINBAN` = `m`.`HINBAN`))) left join `tbuhinjm` `jm` on((`t`.`ID` = `jm`.`BUHIN_KOSEI_ID`))) left join `thatchum` `hm` on((`t`.`ID` = `hm`.`BUHIN_KOSEI_ID`))) left join `mname` `nm` on(((`nm`.`MEISHO_KUBUN` = 48) and (`nm`.`MEISHO_CODE` = `m`.`TANI_CODE`)))) where ((`t`.`KURADASHI_KOTEI` is not null) and (`t`.`KURADASHI_KOTEI` <> '')) group by `t`.`SEIBAN`,`t`.`HINBAN`,`m`.`HINMEI`,`m`.`KIKAKU`,`t`.`KURADASHI_KOTEI`,`nm`.`MEISHO`,`m`.`TANABAN`,`t`.`KOBAI_KUBUN`",
