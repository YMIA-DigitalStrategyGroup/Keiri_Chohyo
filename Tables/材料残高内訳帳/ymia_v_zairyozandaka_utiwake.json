    "SourceTableName": "ymia_v_zairyozandaka_utiwake",
    "SourceTableSchema": "",
    "CreateViewSql": "select `s`.`TARGET_YEAR_MONTH` AS `対象年月`,`kh`.`HIMOKU_CODE` AS `費目`,`hm`.`MEISHO1_KANJI` AS `費目名称`,`kh`.`KANJO_KAMOKU` AS `勘定`,`kh`.`HOJO_KAMOKU` AS `補助`,`kh`.`HOJO_KAMOKU_SEISHIKI_MEISHO` AS `補助科目名称`,sum(`s`.`MAE_ZENZAN`) AS `前月度残高`,sum(`s`.`TO_TOZAN`) AS `当月度残高`,sum(((((`s`.`TO_SHIIRE` + `s`.`TO_URIAGE_YUSHOSHIKYU`) + `s`.`TO_MUSYOSHIKYU`) + `s`.`TO_BANAI_KURADASHI`) + `s`.`TO_SONOTA_KURADASHI`)) AS `当月物流発生`,sum(((`s`.`TO_TOZAN` - `s`.`MAE_ZENZAN`) - ((((`s`.`TO_SHIIRE` + `s`.`TO_URIAGE_YUSHOSHIKYU`) + `s`.`TO_MUSYOSHIKYU`) + `s`.`TO_BANAI_KURADASHI`) + `s`.`TO_SONOTA_KURADASHI`))) AS `評価差額`,(((select ifnull(sum(((`u`.`SEIHIN_KAKAKU` + `u`.`FUTAI_KOJI_KAKAKU`) - `u`.`URIAGE_NEBIKI`)),0) from `tkansayo_seihinuriage_sonotashukka` `u` where (`u`.`TARGET_YEAR_MONTH` = `s`.`TARGET_YEAR_MONTH`)) + (select ifnull(sum(`t`.`KINGAKU1`),0) from `tkansayo_torihiki` `t` where ((`t`.`TARGET_YEAR_MONTH` = `s`.`TARGET_YEAR_MONTH`) and ((`t`.`SAKI_HIMOKU` = 'Z01') or (`t`.`MOTO_HIMOKU` = 'Z01'))))) * 0.002) AS `副資材付替` from (((`tkansayo_zaiko_summary` `s` join `mgentani` `g` on(((`s`.`BUHIN_CODE` = `g`.`HINBAN`) and (`g`.`AVAILABLE_DATE` = (select max(`m2`.`AVAILABLE_DATE`) from `mgentani` `m2` where ((`m2`.`HINBAN` = `g`.`HINBAN`) and (`m2`.`AVAILABLE_DATE` <= `s`.`TARGET_YEAR_MONTH`))))))) join `mhimoku` `hm` on((`g`.`HIMOKU_CODE` = `hm`.`HIMOKU_CODE`))) join `mkanjo_kamoku_henkan` `kh` on((`g`.`HIMOKU_CODE` = `kh`.`HIMOKU_CODE`))) group by `s`.`TARGET_YEAR_MONTH`,`kh`.`KANJO_KAMOKU`,`kh`.`HOJO_KAMOKU`,`kh`.`HIMOKU_CODE`,`hm`.`MEISHO1_KANJI`,`kh`.`HOJO_KAMOKU_SEISHIKI_MEISHO`",
